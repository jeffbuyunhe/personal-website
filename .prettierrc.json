{
    "tabWidth": 4,
    "singleQuote": false,
    "semi": true,
    "trailingComma": "all",
    "printWidth": 100,
    "arrowParens": "always",
    "overrides": [
        { "files": "*.md", "options": { "tabWidth": 2 } },
        { "files": "*.{json,yml,yaml}", "options": { "tabWidth": 2 } }
    ]
}
